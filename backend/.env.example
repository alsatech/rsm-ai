# Django
SECRET_KEY=cambia-esta-clave-por-una-segura-y-unica
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de datos (Postgres en producción, sqlite por defecto en local)
DATABASE_URL=postgres://rsm_user:rsm_password@localhost:5432/rsm_db

# Redis / Celery (alertas y notificaciones)
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MIN=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# CORS — orígenes permitidos del frontend
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
